#!/bin/sh

PROG="/opt/scripts/router_api.py"
PIDFILE="/opt/var/run/router-api.pid"

start() {
    if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE") 2>/dev/null; then
        echo "Router API is already running."
        return 0
    fi
    echo -n "Starting Router API... "
    python3 "$PROG" > /dev/null 2>&1 &
    echo $! > "$PIDFILE"
    echo "done."
}

stop() {
    if [ ! -f "$PIDFILE" ]; then
        echo "Router API is not running."
        return 0
    fi
    echo -n "Stopping Router API... "
    PID=$(cat "$PIDFILE")
    kill "$PID" 2>/dev/null
    # Wait for process to exit
    for i in 1 2 3 4 5; do
        if ! kill -0 "$PID" 2>/dev/null; then
            break
        fi
        sleep 1
    done
    # Force kill if still running
    if kill -0 "$PID" 2>/dev/null; then
        kill -9 "$PID" 2>/dev/null
    fi
    rm -f "$PIDFILE"
    echo "done."
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE") 2>/dev/null; then
        echo "Router API is running (PID $(cat "$PIDFILE"))."
        return 0
    fi
    echo "Router API is stopped."
    return 1
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        start
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
